!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# OS clutter
.DS_Store
Thumbs.db
desktop.ini

# Test reports
surefire-reports/
failsafe-reports/

# Maven wrapper (keep mvnw scripts if present, ignore the cached jar)
.mvn/wrapper/maven-wrapper.jar
